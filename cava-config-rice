# cava config for Vantage's AudioVisualizer.qml
# Installed to ~/.config/cava/cava-config-rice by install.sh
#
# Output format matters here: raw ASCII values separated by ";",
# no newline framing weirdness — AudioVisualizer.qml's SplitParser
# expects exactly this.

[general]
bars = 64
framerate = 60
autosens = 1
sensitivity = 100

[input]
method = pulse
source = auto

[output]
method = raw
raw_target = /dev/stdout
data_format = ascii
ascii_max_range = 100
bar_delimiter = 59
frame_delimiter = 10

[smoothing]
noise_reduction = 60
